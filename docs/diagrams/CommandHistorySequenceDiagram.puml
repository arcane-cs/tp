@startuml
!include style.puml
skinparam ArrowFontStyle plain

box UI UI_COLOR_T1
participant ":CommandBox" as CommandBox UI_COLOR
participant "commandTextField:TextField" as TextField UI_COLOR
end box

box Logic LOGIC_COLOR_T1
participant "commandHistory:CommandHistory" as CommandHistory LOGIC_COLOR
end box

[-> CommandBox : handleKeyPress(KeyEvent.UP)
activate CommandBox

CommandBox -> CommandHistory : getPrevious()
activate CommandHistory

CommandHistory --> CommandBox : previousCommandText
deactivate CommandHistory

opt previousCommandText is not empty
    CommandBox -> TextField : setText(previousCommandText)
    activate TextField
    TextField --> CommandBox
    deactivate TextField

    CommandBox -> TextField : positionCaret(length)
    activate TextField
    TextField --> CommandBox
    deactivate TextField
end

[<-- CommandBox
deactivate CommandBox
@enduml